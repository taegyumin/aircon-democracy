{
  "name": "aircon-democracy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -w @aircon/web dev",
    "build:web": "node scripts/sync-headers.mjs && npm run -w @aircon/web build && (cd apps/web && npx @cloudflare/next-on-pages)",
    "sync:headers": "node scripts/sync-headers.mjs",
    "deploy:web": "npm run -w @aircon/web deploy",
    "test:e2e": "playwright test",
    "test:e2e:prod": "BASE_URL=https://aircondemocracy.com playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "npm run -w @aircon/core test && npm run -w @aircon/web test",
    "check:data": "node scripts/check-data.mjs",
    "check": "npm run check:data && npm run test:unit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@playwright/test": "^1.60.0",
    "turbo": "^2.9.14",
    "typescript": "^5.6.3",
    "wrangler": "^4.86.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4"
  }
}
